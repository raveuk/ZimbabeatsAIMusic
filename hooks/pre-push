#!/usr/bin/env bash
# Pre-push hook — run the Vite production build so a parse error never
# reaches Cloudflare Pages again (cf. commit 9f57fda).
#
# Activate once per clone with:
#   git config core.hooksPath hooks
#
# Skip in emergencies with:
#   git push --no-verify
set -euo pipefail

# Find the repo root so the hook works no matter where the user invokes
# `git push` from.
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT/web"

# Fast bail-outs: nothing to check if web/ is missing deps. Telling the user
# WHY we skipped is more useful than silently passing.
if [ ! -d node_modules ]; then
  echo "↻ pre-push: web/node_modules missing — run \`cd web && npm install\` before pushing."
  exit 1
fi

echo "↻ pre-push: building web/ to catch parse/type errors before Cloudflare Pages…"
if ! npm run build --silent >/tmp/musicapp-prepush.log 2>&1; then
  echo "✗ pre-push: build FAILED. Tail of the log:"
  tail -30 /tmp/musicapp-prepush.log
  echo ""
  echo "Full log: /tmp/musicapp-prepush.log"
  echo "Bypass (only in emergencies): git push --no-verify"
  exit 1
fi
echo "✓ pre-push: build OK"
